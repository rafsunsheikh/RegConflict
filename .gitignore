# Local model artefacts (DeBERTa weights, GGUFs, etc. — fetched on demand)
*.bin
*.safetensors
*.gguf
*.pt
*.pth

# Runtime outputs — regenerated by users from the released code + data
results/
data/corpus/tier3_metadata_only/fetch_log.jsonl
data/corpus/tier3_metadata_only/_sha256_mismatch/
data/corpus/tier3_metadata_only/[0-9a-f]*/

# QC reports produced by chunk_corpus.py (regenerated per-machine; not part of release)
data/qc_reports/

# Tier 3 extracted/chunks files (regenerated locally via chunk_corpus.py after
# the user fetches Tier 3 PDFs; not redistributable under source licenses).
# Tier 1+2 extracted/chunks files ARE shipped and tracked.
# Pattern: anything in extracted/<jurisdiction>/<source>/ where source matches Tier 3
data/extracted/Singapore/MAS-*/
data/extracted/Singapore/IRAS/
data/extracted/International/FATF/
data/chunks/Singapore/MAS-*/
data/chunks/Singapore/IRAS/
data/chunks/International/FATF/

# The Tier 3 fetched documents themselves (per-user reconstruction, never committed)
# — but DO commit the manifest.csv and README.md
!data/corpus/tier3_metadata_only/manifest.csv
!data/corpus/tier3_metadata_only/README.md

# Editor backup files
*~
*.bak
